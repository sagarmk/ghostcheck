# =============================================================================
# AI Code Verifier (.env.example)
# =============================================================================
# Copy to .env and fill in values as needed.
# None of these are required — ACV works with zero configuration.
# =============================================================================

# npm registry URL override (default: https://registry.npmjs.org)
# ACV_REGISTRY_URL=https://registry.npmjs.org

# Disable npm registry checks entirely (offline mode)
# ACV_SKIP_REGISTRY=true

# Default output format: pretty | json | sarif | junit | github
# ACV_FORMAT=pretty

# Maximum file size to scan (default: 1mb)
# ACV_MAX_FILE_SIZE=1mb

# Enable debug logging
# ACV_DEBUG=true

# CI mode — automatically detected, but can be forced
# CI=true
